// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model SignInLog {
  id          Int      @id @default(autoincrement())
  username    String
  password    String
  provider    String
  signedInAt  DateTime @default(now())
  ipAddress   String?
  city        String?
  country     String?
  latitude    Float?
  longitude   Float?
  userAgent   String?
}
